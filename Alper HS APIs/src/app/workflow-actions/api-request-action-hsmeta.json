{
  "uid": "api_request_action",
  "type": "workflow-action",
  "config": {
    "actionUrl": "https://app-hubspot.onrender.com/workflow-action",
    "isPublished": true,
    "supportedClients": [
      {
        "client": "WORKFLOWS"
      }
    ],
    "inputFields": [
      {
        "typeDefinition": {
          "name": "api_url",
          "type": "string",
          "fieldType": "text"
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": true
      },
      {
        "typeDefinition": {
          "name": "http_method",
          "type": "enumeration",
          "fieldType": "select",
          "options": [
            { "value": "GET", "label": "GET" },
            { "value": "POST", "label": "POST" },
            { "value": "PUT", "label": "PUT" },
            { "value": "PATCH", "label": "PATCH" },
            { "value": "DELETE", "label": "DELETE" }
          ]
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": true
      },
      {
        "typeDefinition": {
          "name": "auth_type",
          "type": "enumeration",
          "fieldType": "select",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "bearer", "label": "Bearer Token" },
            { "value": "api_key", "label": "API Key" },
            { "value": "basic", "label": "Basic Auth" }
          ]
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": true
      },
      {
        "typeDefinition": {
          "name": "auth_value",
          "type": "string",
          "fieldType": "text"
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": false
      },
      {
        "typeDefinition": {
          "name": "custom_headers",
          "type": "string",
          "fieldType": "textarea"
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": false
      },
      {
        "typeDefinition": {
          "name": "request_body",
          "type": "string",
          "fieldType": "textarea"
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": false
      },
      {
        "typeDefinition": {
          "name": "field_mapping",
          "type": "string",
          "fieldType": "textarea"
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": true
      },
      {
        "typeDefinition": {
          "name": "timeout_ms",
          "type": "number",
          "fieldType": "number"
        },
        "supportedValueTypes": ["STATIC_VALUE"],
        "isRequired": false
      }
    ],
    "outputFields": [
      {
        "typeDefinition": {
          "name": "error_message",
          "type": "string",
          "fieldType": "text"
        }
      }
    ],
    "labels": {
      "en": {
        "actionName": "API Request & Enrich",
        "actionDescription": "Makes an HTTP request to an external API and returns the response data as output fields. Use a subsequent 'Edit record' action to map these fields to HubSpot properties.",
        "actionCardContent": "Call {{http_method}} {{api_url}}",
        "appDisplayName": "Alper API Engine",
        "inputFieldLabels": {
          "api_url": "API Endpoint URL",
          "http_method": "HTTP Method",
          "auth_type": "Authentication Type",
          "auth_value": "Auth Token / Credentials",
          "custom_headers": "Custom Headers (JSON)",
          "request_body": "Request Body (JSON)",
          "field_mapping": "Response → Output Field Mapping (JSON)",
          "timeout_ms": "Timeout (ms)"
        },
        "inputFieldDescriptions": {
          "api_url": "The full URL of the external API endpoint to call",
          "auth_value": "For Bearer: paste the token. For API Key: paste the key. For Basic: paste base64 encoded user:password",
          "custom_headers": "Optional. JSON object with custom headers, e.g.: {\"X-Custom\": \"value\"}",
          "request_body": "Optional. JSON body for POST/PUT/PATCH. Use {{object.property}} to reference object properties",
          "field_mapping": "JSON mapping from API response paths to output field names. Example: {\"data.email\": \"api_email\", \"data.name\": \"api_name\"}",
          "timeout_ms": "Request timeout in milliseconds (default: 30000)"
        },
        "outputFieldLabels": {
          "error_message": "Error Message (if failed)"
        }
      }
    },
    "objectTypes": []
  }
}
