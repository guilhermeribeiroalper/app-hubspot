    "labels": {
      "en": {
        "actionName": "Normalize Phone Number",
        "actionDescription": "Receives a phone number in international format (e.g. +55-99999-0000 or +1-415-555-0123) and returns the digits only, without the leading country code. Use the 'phone_clean' output with a subsequent 'Edit record' action to map it to a HubSpot property such as 'phone'.",
        "actionCardContent": "Normalize: {{raw_phone}}",
        "appDisplayName": "Alper API Engine",
        "inputFieldLabels": {
          "raw_phone": "Raw Phone Number"
        },
        "inputFieldDescriptions": {
          "raw_phone": "Phone number in international format, optionally starting with + and a country code separated by '-' (e.g. +55-99999-0000, +1-415-555-0123). If no '+' is present, the original digits are returned unchanged."
        },
        "outputFieldLabels": {
          "error_message": "Error Message (if failed)",
          "phone_clean": "Cleaned Phone (digits only, no country code)",
          "country_code": "Detected Country Code",
          "digit_count": "Total Digit Count (after cleaning)",
          "had_plus": "Had Leading Plus Sign (true/false)"
        }
      }
    },
    "objectTypes": [
      "CONTACT",
      "COMPANY",
      "DEAL"
    ]
  }
}
